# ── 数据库 ──────────────────────────────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=global_picker

# ── Redis ───────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USER=
REDIS_PASSWORD=
REDIS_DB=0

# ── 应用 ────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change_me_in_production_32chars!!
ACCESS_TOKEN_EXPIRE_MINUTES=10080
# 可选：截图/工件目录，默认 <仓库根>/artifacts（勿再使用 macOS 绝对路径）
# GLOBAL_PICKER_ARTIFACTS_DIR=/var/lib/global_picker/artifacts

# ── 跨域 ────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── 阿里云 OSS ───────────────────────────────────────────────
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=global-picker-pdd-image
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
OSS_CDN_DOMAIN=

# ── 阿里云短信 ────────────────────────────────────────────────
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=GlobalPicker
ALIYUN_SMS_TEMPLATE_CODE=SMS_123456789
SMS_CODE_EXPIRE_MINUTES=5
SMS_CODE_LENGTH=6
SMS_SEND_INTERVAL_SECONDS=60

# 拍照购：是否在结果页点进详情解析 goods_id（每条约 +3s）
PDD_EXTRACT_PRODUCT_LINKS=true

# ── TikTok 采集 ──────────────────────────────────────────────
# 代理（可选）：http://user:pass@host:port 或 socks5://host:port
TIKTOK_PROXY=
# Cookie（可选）：从浏览器 DevTools > Application > Cookies > shop.tiktok.com 复制
TIKTOK_COOKIES=
# 浏览器模式：False=显示窗口(可手动过验证)  True=无界面后台运行
TIKTOK_HEADLESS=False

# ── 云手机 Chinac OpenAPI（拍照购 / 云手机池）──────────────────
# 控制台创建 AccessKey：https://console.chinac.com  勿将密钥提交到 Git
CHINAC_ACCESS_KEY_ID=
CHINAC_ACCESS_KEY_SECRET=
