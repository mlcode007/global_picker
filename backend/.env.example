# ── 数据库 ──────────────────────────────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=global_picker

# ── Redis ───────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USER=
REDIS_PASSWORD=
REDIS_DB=0

# ── 应用 ────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change_me_in_production_32chars!!
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── 跨域 ────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── TikTok 采集 ──────────────────────────────────────────────
# 代理（可选）：http://user:pass@host:port 或 socks5://host:port
TIKTOK_PROXY=
# Cookie（可选）：从浏览器 DevTools > Application > Cookies > shop.tiktok.com 复制
TIKTOK_COOKIES=
# 浏览器模式：False=显示窗口(可手动过验证)  True=无界面后台运行
TIKTOK_HEADLESS=False
